rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /heroSections/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /heroImages_home/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /heroImages_news/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /heroImages_gallery/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /heroImages_dailywork/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /heroImages_super6/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /heroImages_schemes/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /heroImages_narasaraopet/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /heroImages_contact/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /dailyWork/{document} {
      allow read: if resource.data.isPublished == true || request.auth != null;
      allow write: if request.auth != null;
    }
    match /dailySchedules/{document} {
      allow read: if resource.data.isPublished == true || request.auth != null;
      allow write: if request.auth != null;
    }
    match /news/{document} {
      allow read: if resource.data.isPublished == true || request.auth != null;
      allow write: if request.auth != null;
    }
    match /gallery/{document} {
      allow read: if resource.data.isPublished == true || request.auth != null;
      allow write: if request.auth != null;
    }
    match /achievements/{document} {
      allow read: if resource.data.isPublished == true || request.auth != null;
      allow write: if request.auth != null;
    }
    match /schemes/{document} {
      allow read: if resource.data.isPublished == true || request.auth != null;
      allow write: if request.auth != null;
    }
    match /super6Schemes/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /super6Banners/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /towns/{document} {
      allow read: if resource.data.isPublished == true || request.auth != null;
      allow write: if request.auth != null;
    }
    match /festivalBanners/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /announcements/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /narasaraopetSections/{document} {
      allow read: if resource.data.isPublished == true || request.auth != null;
      allow write: if request.auth != null;
    }
    match /siteConfig/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /tickerNews/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /contactRequests/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    match /analytics/{document} {
      allow create, update: if true;
      allow read, delete: if request.auth != null;
    }
    match /adminSettings/{document} {
      allow read, write: if request.auth != null;
    }
  }
}
